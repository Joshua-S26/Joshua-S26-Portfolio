annotation PBI_ProTooling = ["MCP-PBIModeling","DevMode"]

ref table Dim_Date
ref table Dim_Customer
ref table Dim_Product
ref table Dim_Seller
ref table Fact_Orders
ref table Fact_OrderItems
ref table _Measures

ref cultureInfo en-US

